{
  "id": "store_skipped_after_expect_fail",
  "description": "Spec §4.6 + §7: .store() is skipped when any preceding chain method on the same call hard-failed. With expect(status: 200) failing, the .store() entries must NOT appear in runVars or actions.variables.",
  "spec_refs": [
    "lace-spec.md §4.6",
    "lace-spec.md §7",
    "lace-spec.md §15.7"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"$BASE_URL/x\").expect(status: 200).store({ \"$$token\": this.body.t, last: this.body.t })\n",
    "variables": {
      "BASE_URL": "http://127.0.0.1:{port}"
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 500,
        "headers": {
          "content-type": "application/json"
        },
        "body": "{\"t\": \"never_stored\"}"
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "failure",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "failure",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": {
            "url": "http://127.0.0.1:{port}/x",
            "method": "get",
            "headers": {}
          },
          "response": {
            "status": 500,
            "statusText": "Internal Server Error",
            "headers": {
              "content-type": "application/json"
            },
            "bodyPath": "/ignored",
            "responseTimeMs": 0,
            "dnsMs": 0,
            "connectMs": 0,
            "tlsMs": 0,
            "ttfbMs": 0,
            "transferMs": 0,
            "sizeBytes": 21
          },
          "redirects": [],
          "assertions": [
            {
              "method": "expect",
              "scope": "status",
              "op": "eq",
              "outcome": "failed",
              "actual": 500,
              "expected": 200,
              "options": null
            }
          ],
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].response.bodyPath",
      "calls[*].response.responseTimeMs",
      "calls[*].response.dnsMs",
      "calls[*].response.connectMs",
      "calls[*].response.ttfbMs",
      "calls[*].response.transferMs",
      "calls[*].config"
    ]
  }
}
