{
  "id": "writeback_appears_in_actions_variables",
  "description": ".store() keys without the $$ prefix are writeback; their final values appear in actions.variables. $name keys have the $ stripped. $$-prefixed keys appear in runVars instead (spec §4.6, §9.3, §15.7).",
  "spec_refs": [
    "lace-spec.md §4.6",
    "lace-spec.md §9.3",
    "lace-spec.md §15.7"
  ],
  "type": "execute",
  "requires": [
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200).store({ \"$$run_only\": \"r1\", \"$cursor\": \"abc\", writeback_plain: \"w1\" })\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "run_only": "r1"
      },
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": [
            {
              "method": "expect",
              "scope": "status",
              "op": "eq",
              "outcome": "passed",
              "actual": 200,
              "expected": 200,
              "options": null
            }
          ],
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {
        "variables": {
          "cursor": "abc",
          "writeback_plain": "w1"
        }
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].config"
    ]
  }
}
