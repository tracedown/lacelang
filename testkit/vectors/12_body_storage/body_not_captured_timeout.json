{
  "id": "body_not_captured_timeout",
  "description": "On a hard-fail timeout (`timeout.action: \"fail\"`), no response body can be captured because no response was received. Per spec \u00a79.4 `calls[n].response` is `null` for timeout, skipped, or connection failure. Spec \u00a715.12 lists `\"timeout\"` as a valid `bodyNotCapturedReason`, but with a null `response` there is no response object to attach the reason to \u2014 so the observable shape is simply `response: null`. The request was sent but never completed, so `request.bodyPath` is also `null` (GET carries no body).",
  "spec_refs": [
    "lace-spec.md \u00a79.4",
    "lace-spec.md \u00a715.12"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/slow\", { timeout: { ms: 100, action: \"fail\" } }).expect(status: 200)\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "timeout"
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "timeout",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "timeout",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": {
            "url": "http://127.0.0.1:{port}/slow",
            "method": "get",
            "headers": {},
            "bodyPath": null
          },
          "response": null,
          "redirects": [],
          "assertions": [],
          "config": {},
          "warnings": [],
          "error": "IGNORED"
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].config",
      "calls[*].error"
    ]
  }
}
