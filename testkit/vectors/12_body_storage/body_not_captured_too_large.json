{
  "id": "body_not_captured_too_large",
  "description": "Per spec \u00a74.2 / \u00a79.4 / \u00a715.12, the `bodySize` scope also gates response-body capture: a response whose body exceeds the threshold is not written to `bodyPath` and the call records `bodyNotCapturedReason: \"bodyTooLarge\"` on the response object. Here we assert against a 10-byte threshold but the mock returns a 100-byte body, so the executor must skip body capture and record the reason. The scope itself fails (`.expect(bodySize: \"10\")`), which cascades to call outcome `failure` and result outcome `failure`.",
  "spec_refs": [
    "lace-spec.md \u00a74.2",
    "lace-spec.md \u00a79.4",
    "lace-spec.md \u00a715.12"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/big\").expect(bodySize: \"10\")\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {
          "content-type": "text/plain"
        },
        "body": "0123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890123456789"
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "failure",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "failure",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": {
            "url": "http://127.0.0.1:{port}/big",
            "method": "get",
            "headers": {},
          },
          "response": {
            "status": 200,
            "statusText": "OK",
            "headers": {
              "content-type": "text/plain"
            },
            "bodyPath": null,
            "bodyNotCapturedReason": "bodyTooLarge",
            "responseTimeMs": 0,
            "dnsMs": 0,
            "connectMs": 0,
            "tlsMs": 0,
            "ttfbMs": 0,
            "transferMs": 0,
            "sizeBytes": 100
          },
          "redirects": [],
          "assertions": "IGNORED",
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",

      "calls[*].response.responseTimeMs",
      "calls[*].response.dnsMs",
      "calls[*].response.connectMs",
      "calls[*].response.ttfbMs",
      "calls[*].response.transferMs",
      "calls[*].assertions",
      "calls[*].config"
    ]
  }
}
