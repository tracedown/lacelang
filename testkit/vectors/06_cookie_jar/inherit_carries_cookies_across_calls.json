{
  "id": "inherit_carries_cookies_across_calls",
  "description": "cookieJar: \"inherit\" (the default) carries Set-Cookie headers from call 0 to the jar used by call 1 (spec \u00a73.3, \u00a715.6). Test server echoes 'Cookie:' back in the response body; call 1's response must contain the session cookie set by call 0.",
  "spec_refs": [
    "lace-spec.md \u00a73.3",
    "lace-spec.md \u00a715.6"
  ],
  "type": "execute",
  "input": {
    "source": "post(\"http://127.0.0.1:{port}/login\").expect(status: 200)\nget(\"http://127.0.0.1:{port}/echo-cookies\").expect(status: 200, body: \"sid=abc123\")\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {
          "set-cookie": "sid=abc123; Path=/"
        },
        "body": ""
      },
      {
        "callIndex": 1,
        "outcome": "response",
        "status": 200,
        "headers": {
          "content-type": "text/plain"
        },
        "body": "sid=abc123"
      }
    ]
  },
  "expected": {
