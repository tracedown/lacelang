    "source": "post(\"http://127.0.0.1:{port}/admin/login\", { cookieJar: \"named:admin\" }).expect(status: 200)\npost(\"http://127.0.0.1:{port}/user/login\", { cookieJar: \"named:user\" }).expect(status: 200)\nget(\"http://127.0.0.1:{port}/echo-cookies\", { cookieJar: \"named:admin\" }).expect(status: 200, body: \"sid=admin\")\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {
          "set-cookie": "sid=admin; Path=/"
        },
        "body": ""
      },
      {
        "callIndex": 1,
        "outcome": "response",
        "status": 200,
        "headers": {
          "set-cookie": "sid=user; Path=/"
        },
        "body": ""
