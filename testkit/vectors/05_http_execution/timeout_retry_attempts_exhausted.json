{
  "id": "timeout_retry_attempts_exhausted",
  "description": "`timeout: { action: \"retry\", retries: 2 }` attempts the call up to `retries + 1 = 3` times (spec \u00a715.5). When every attempt times out, the call hard-fails with outcome `timeout` and the run outcome is `timeout`. The mock is primed with three timeout responses \u2014 one per attempt \u2014 and none of them are consumed as a success.",
  "spec_refs": [
    "lace-spec.md \u00a73.2",
    "lace-spec.md \u00a715.5"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/slow\", { timeout: { ms: 100, action: \"retry\", retries: 2 } }).expect(status: 200)\n",
    "variables": {},
    "http_mock": [
      { "callIndex": 0, "outcome": "timeout" },
      { "callIndex": 1, "outcome": "timeout" },
      { "callIndex": 2, "outcome": "timeout" }
    ]
  },
  "expected": {
    "result": {
      "outcome": "timeout",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "timeout",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": null,
          "redirects": [],
          "assertions": [],
          "config": {},
          "warnings": [],
          "error": "IGNORED"
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].config",
      "calls[*].error"
    ]
  }
}
