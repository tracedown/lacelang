{
  "id": "interpolation_in_url",
  "description": "Variable interpolation in the request URL: `$path` in the URL string is replaced with the value of the injected script variable `path` before the request is issued (spec §3.5, §15.5). The resolved URL appears on calls[0].request.url.",
  "spec_refs": [
    "lace-spec.md §3.5",
    "lace-spec.md §15.5"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/$path\").expect(status: 200)\n",
    "variables": {
      "path": "hello"
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": {
            "url": "http://127.0.0.1:{port}/hello",
            "method": "get",
            "headers": "IGNORED"
          },
          "response": "IGNORED",
          "redirects": [],
          "assertions": [
            {
              "method": "expect",
              "scope": "status",
              "op": "eq",
              "outcome": "passed",
              "actual": 200,
              "expected": 200,
              "options": null
            }
          ],
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].response",
      "calls[*].config"
    ]
  }
}
