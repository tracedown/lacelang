{
  "id": "interpolation_in_body",
  "description": "Variable interpolation in a raw-string request body: `$v` in the body literal is replaced with the injected script variable value before the request is issued (spec \u00a73.5, \u00a715.5). A successful call with no warnings (and `$$resolved` captured via .store for positive confirmation) means the variable bound correctly; a missing variable would produce the literal string \"null\" plus a warning.",
  "spec_refs": [
    "lace-spec.md \u00a73.5",
    "lace-spec.md \u00a715.5"
  ],
  "type": "execute",
  "input": {
    "source": "post(\"http://127.0.0.1:{port}/x\", { body: \"value=$v\" }).expect(status: 200).store({ \"$$resolved\": \"$v\" })\n",
    "variables": {
      "v": "42"
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "resolved": "42"
      },
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": [
            {
              "method": "expect",
              "scope": "status",
              "op": "eq",
              "outcome": "passed",
              "actual": 200,
              "expected": 200,
              "options": null
            }
          ],
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].config"
    ]
  }
}
