{
  "id": "run_var_propagates_across_calls",
  "description": "$$var assigned in call 0's .store() is available in call 1's expressions and string interpolation. runVars in the final result contains the assigned value.",
  "spec_refs": [
    "lace-spec.md \u00a75.2",
    "lace-spec.md \u00a715.3"
  ],
  "type": "execute",
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/first\").expect(status: 200).store({ \"$$token\": this.body.t })\nget(\"http://127.0.0.1:{port}/second\", { headers: { Authorization: \"Bearer $$token\" } }).expect(status: 200)\n",
    "variables": {},
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {
          "content-type": "application/json"
        },
        "body": "{\"t\": \"abc123\"}"
      },
      {
        "callIndex": 1,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
