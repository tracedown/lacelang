{
  "id": "hook_before_call_and_call_fire",
  "description": "The `before call` and `call` hook points each fire exactly once per call. `hookTrace` registers rules on every hook and emits a tagged entry per firing into `result.actions.hook_trace`. This vector asserts the call-level pair is present in the recorded sequence at the expected positions: `before call` is the first entry (fires before wire activity) and `call` is the last entry (fires after the record is finalised). Spec \u00a715.14, lace-extensions.md \u00a78.2.",
  "spec_refs": [
    "lace-spec.md \u00a715.14",
    "lace-extensions.md \u00a78.1",
    "lace-extensions.md \u00a78.2"
  ],
  "type": "extension",
  "requires": [
    "extensions",
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": [
      "hookTrace"
    ],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": "IGNORED",
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {
        "hook_trace": [
          {
            "callIndex": -1,
            "hook": "before script"
          },
          {
            "callIndex": 0,
            "hook": "before call"
          },
          {
            "callIndex": 0,
            "hook": "before expect"
          },
          {
            "callIndex": 0,
            "hook": "expect"
          },
          {
            "callIndex": 0,
            "hook": "call"
          },
          {
            "callIndex": -1,
            "hook": "script"
          }
        ]
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].assertions",
      "calls[*].config"
    ]
  }
}
