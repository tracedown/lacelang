{
  "id": "extension_emit_namespace_rejected",
  "description": "Per spec \u00a715.14 and lace-extensions.md \u00a79, extensions may only write to `result.runVars` keys prefixed with `{extension_name}.`. The `badNamespace` extension deliberately emits `stolen_key` (no prefix) on the `call` hook \u2014 the executor must reject the emit so the key never appears in the result. A compliant executor either hard-fails the probe or drops the emit with a warning; in both cases the final `runVars` must NOT contain `stolen_key`.",
  "spec_refs": [
    "lace-spec.md \u00a715.14",
    "lace-extensions.md \u00a79"
  ],
  "type": "extension",
  "requires": [
    "extensions",
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": [
      "badNamespace"
    ],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": "IGNORED",
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].assertions",
      "calls[*].config"
    ]
  }
}
