{
  "id": "full_form_scope_with_op",
  "description": "A scope in full form { value, op, options } parses with op preserved and options passed through.",
  "spec_refs": ["lace-spec.md §4.3"],
  "type": "parse",
  "input": {
    "source": "get(\"$x\").expect(totalDelayMs: { value: 500, op: \"lte\", options: {} })\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.0",
      "calls": [
        {
          "method": "get",
          "url": "$x",
          "chain": {
            "expect": {
              "totalDelayMs": {
                "value": { "kind": "literal", "valueType": "int", "value": 500 },
                "op": "lte",
                "options": {}
              }
            }
          }
        }
      ]
    }
  }
}
