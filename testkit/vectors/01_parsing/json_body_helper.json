{
  "id": "json_body_helper",
  "description": "`body: json({ key: \"val\" })` parses to a typed json body with an object literal value (spec §3.2).",
  "spec_refs": ["lace-spec.md §3.2"],
  "type": "parse",
  "input": {
    "source": "post(\"$url\", { body: json({ email: \"$e\", password: \"$p\" }) }).expect(status: 200)\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.0",
      "calls": [
        {
          "method": "post",
          "url": "$url",
          "config": {
            "body": {
              "type": "json",
              "value": {
                "kind": "objectLit",
                "entries": [
                  { "key": "email",    "value": { "kind": "scriptVar", "name": "e" } },
                  { "key": "password", "value": { "kind": "scriptVar", "name": "p" } }
                ]
              }
            }
          },
          "chain": {
            "expect": {
              "status": { "value": { "kind": "literal", "valueType": "int", "value": 200 } }
            }
          }
        }
      ]
    }
  }
}
