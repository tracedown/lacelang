{
  "id": "null_and_float_literals",
  "description": "null and floating-point literals both parse; null emits value_type:'null' and float emits value_type:'float' (spec §2.1, §2.2).",
  "spec_refs": [
    "lace-spec.md §2.1"
  ],
  "type": "parse",
  "input": {
    "source": "get(\"$u\").expect(status: 200).assert({ expect: [this.size eq 3.14, this.body eq null] })\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.1",
      "calls": [
        {
          "method": "get",
          "url": "$u",
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "literal",
                  "valueType": "int",
                  "value": 200
                }
              }
            },
            "assert": {
              "expect": [
                {
                  "condition": {
                    "kind": "binary",
                    "op": "eq",
                    "left": {
                      "kind": "thisRef",
                      "path": [
                        "size"
                      ]
                    },
                    "right": {
                      "kind": "literal",
                      "valueType": "float",
                      "value": 3.14
                    }
                  }
                },
                {
                  "condition": {
                    "kind": "binary",
                    "op": "eq",
                    "left": {
                      "kind": "thisRef",
                      "path": [
                        "body"
                      ]
                    },
                    "right": {
                      "kind": "literal",
                      "valueType": "null",
                      "value": null
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
