{
  "id": "interpolation_expr_form",
  "description": "A URL string containing `${expr}` is preserved verbatim as the URL literal by the lexer/parser — interpolation is re-scanned at executor time (spec §3.5). The parse only needs the raw token content to round-trip.",
  "spec_refs": [
    "lace-spec.md §3.5"
  ],
  "type": "parse",
  "input": {
    "source": "get(\"http://h.x/${$var + 1}\").expect(status: 200)\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.1",
      "calls": [
        {
          "method": "get",
          "url": "http://h.x/${$var + 1}",
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "literal",
                  "valueType": "int",
                  "value": 200
                }
              }
            }
          }
        }
      ]
    }
  }
}
