{
  "id": "minimal_get_expect",
  "description": "A minimal GET with .expect(status: ...) parses to the canonical AST shape.",
  "spec_refs": [
    "lace-spec.md §2.1",
    "lace-spec.md §4.1"
  ],
  "type": "parse",
  "input": {
    "source": "get(\"$BASE_URL/health\").expect(status: 200)\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.1",
      "calls": [
        {
          "method": "get",
          "url": "$BASE_URL/health",
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "literal",
                  "valueType": "int",
                  "value": 200
                }
              }
            }
          }
        }
      ]
    }
  }
}
