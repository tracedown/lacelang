{
  "id": "scope_value_op_form_isolated",
  "description": "Scope full form with both `value` and `op` (no options) parses to a scope node carrying value and op fields (spec §4.3).",
  "spec_refs": [
    "lace-spec.md §4.3"
  ],
  "type": "parse",
  "input": {
    "source": "get(\"$u\").expect(status: { value: 200, op: \"eq\" })\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.1",
      "calls": [
        {
          "method": "get",
          "url": "$u",
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "literal",
                  "valueType": "int",
                  "value": 200
                },
                "op": "eq"
              }
            }
          }
        }
      ]
    }
  }
}
