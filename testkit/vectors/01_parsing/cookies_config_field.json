{
  "id": "cookies_config_field",
  "description": "Call config `cookies: { ... }` parses to a map of name \u2192 expression on config.cookies (spec \u00a73.2).",
  "spec_refs": [
    "lace-spec.md \u00a73.2"
  ],
  "type": "parse",
  "input": {
    "source": "get(\"x\", { cookies: { sessionId: \"abc\" } }).expect(status: 200)\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.0",
      "calls": [
        {
          "method": "get",
          "url": "x",
          "config": {
            "cookies": {
              "sessionId": {
                "kind": "literal",
                "valueType": "string",
                "value": "abc"
              }
            }
          },
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "literal",
                  "valueType": "int",
                  "value": 200
                }
              }
            }
          }
        }
      ]
    }
  }
}
