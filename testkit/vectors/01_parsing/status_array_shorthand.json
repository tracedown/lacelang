{
  "id": "status_array_shorthand",
  "description": "`status: [200, 201, 204]` parses to an array_lit as the scope value — spec §4.1, §4.3.",
  "spec_refs": [
    "lace-spec.md §4.1",
    "lace-spec.md §4.3"
  ],
  "type": "parse",
  "input": {
    "source": "post(\"$url\").expect(status: [200, 201, 204])\n"
  },
  "expected": {
    "ast": {
      "version": "0.9.1",
      "calls": [
        {
          "method": "post",
          "url": "$url",
          "chain": {
            "expect": {
              "status": {
                "value": {
                  "kind": "arrayLit",
                  "items": [
                    {
                      "kind": "literal",
                      "valueType": "int",
                      "value": 200
                    },
                    {
                      "kind": "literal",
                      "valueType": "int",
                      "value": 201
                    },
                    {
                      "kind": "literal",
                      "valueType": "int",
                      "value": 204
                    }
                  ]
                }
              }
            }
          }
        }
      ]
    }
  }
}
