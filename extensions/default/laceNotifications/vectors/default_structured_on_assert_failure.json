{
  "id": "default_structured_on_assert_failure",
  "description": "When no custom notification option is set on an assert condition, a default structured() notification is emitted with expression details.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/fail\").assert({ expect: [this.status eq 200] })\n",
    "variables": {},
    "extensions": ["laceNotifications"],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 503,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "failure",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "notifications": [
          {
            "callIndex": 0,
            "conditionIndex": 0,
            "trigger": "assert",
            "notification": {
              "tag": "structured",
              "data": {
                "kind": "expect",
                "expression": "this.status eq 200",
                "actualLhs": 503,
                "actualRhs": 200
              }
            }
          }
        ]
      }
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
