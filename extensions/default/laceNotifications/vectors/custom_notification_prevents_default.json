{
  "id": "custom_notification_prevents_default",
  "description": "When a custom notification option is set on a scope, only the custom notification is emitted — no duplicate default structured() notification.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/fail\").expect(status: { value: 200, op: \"eq\", options: { notification: text(\"custom alert\") } })\n",
    "variables": {},
    "extensions": ["laceNotifications"],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 503,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "failure",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "notifications": [
          {
            "callIndex": 0,
            "conditionIndex": -1,
            "trigger": "expect",
            "scope": "status",
            "notification": {
              "tag": "text",
              "value": "custom alert"
            }
          }
        ]
      }
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
