{
  "id": "default_timeout_notification",
  "description": "When a call times out and no custom timeout notification is configured, a default text() notification is emitted using config.timeout_message.",
  "spec_refs": ["lace-extensions.md §12"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/slow\", { timeout: { ms: 100, action: \"fail\" } }).expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications"],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "timeout"
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "timeout",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "notifications": [
          {
            "callIndex": 0,
            "conditionIndex": -1,
            "trigger": "timeout",
            "notification": {
              "tag": "text",
              "value": "Request timed out"
            }
          }
        ]
      }
    },
    "ignore": ["startedAt", "endedAt", "calls"]
  }
}
