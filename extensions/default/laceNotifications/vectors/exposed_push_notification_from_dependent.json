{
  "id": "exposed_push_notification_from_dependent",
  "description": "laceNotifications declares `pushNotification` as an `exposed = true` function (spec \u00a76.1). Any extension that `require`s laceNotifications can call it with `laceNotifications.pushNotification({...})` from its own rule bodies. The emit attributes to laceNotifications (the owner), so the event lands in `result.actions.notifications`. Here `notifRelay` calls it from an `on call after laceNotifications` rule on every successful call.",
  "spec_refs": [
    "lace-spec.md \u00a715.14",
    "lace-extensions.md \u00a76.1",
    "lace-extensions.md \u00a710",
    "lace-extensions.md \u00a712"
  ],
  "type": "extension",
  "requires": [
    "extensions",
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": [
      "laceNotifications",
      "notifRelay"
    ],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "notifications": [
          {
            "callIndex": 0,
            "conditionIndex": -1,
            "trigger": "relay",
            "scope": null,
            "notification": {
              "tag": "text",
              "value": "hello from notifRelay"
            }
          }
        ]
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls"
    ]
  }
}
