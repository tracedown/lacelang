{
  "id": "notification_event_persists_after_later_hard_fail",
  "description": "Spec \u00a715.10: notification events produced by soft failures in earlier calls are still present in actions.notifications even after a later call hard-fails. Call 0 soft-fails a .check() that emits a notification; call 1 hard-fails; the notification remains in actions.",
  "spec_refs": [
    "lace-spec.md \u00a715.10"
  ],
  "type": "extension",
  "requires": [
    "extensions",
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/a\").check(status: { value: 200, op: \"eq\", options: { notification: text(\"soft note\") } })\nget(\"http://127.0.0.1:{port}/b\").expect(status: 200)\n",
    "variables": {},
    "extensions": [
      "laceNotifications"
    ],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 500,
        "headers": {},
        "body": ""
      },
      {
        "callIndex": 1,
        "outcome": "response",
        "status": 500,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "failure",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": "IGNORED",
          "config": {},
          "warnings": [],
          "error": null
        },
        {
          "index": 1,
          "outcome": "failure",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": "IGNORED",
          "config": {},
          "warnings": [],
          "error": null
        }
      ],
      "actions": {
        "notifications": [
          {
            "callIndex": 0,
            "conditionIndex": -1,
            "trigger": "check",
            "scope": "status",
            "notification": {
              "tag": "text",
              "value": "soft note"
            }
          },
          {
            "callIndex": 1,
            "conditionIndex": -1,
            "trigger": "expect",
            "scope": "status",
            "notification": {
              "tag": "structured",
              "data": {
                "scope": "status",
                "op": "eq",
                "expected": 200,
                "actual": 500
              }
            }
          }
        ]
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].assertions",
      "calls[*].config"
    ]
  }
}
