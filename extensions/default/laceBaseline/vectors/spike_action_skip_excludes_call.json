{
  "id": "spike_action_skip_excludes_call",
  "description": "With spike_action=skip, a spiking call is excluded from stats accumulation via internal threshold re-check. The count remains unchanged from prev when all calls spike.",
  "spec_refs": ["lace-extensions.md §12.1"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceBaseline"],
    "lace_config": "[extensions.laceBaseline]\nspike_multiplier = 1.0\nspike_action = \"skip\"\n",
    "prev_results": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "laceBaseline.stats": {
          "count": 10,
          "sums": {
            "responseTimeMs": 0.01,
            "dnsMs": 0.0,
            "connectMs": 0.01,
            "tlsMs": 0.0,
            "ttfbMs": 0.01,
            "transferMs": 0.01,
            "sizeBytes": 0.0
          }
        }
      },
      "calls": [],
      "actions": {}
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "laceBaseline.stats": {
          "count": 10,
          "sums": {
            "responseTimeMs": 0.01,
            "dnsMs": 0.0,
            "connectMs": 0.01,
            "tlsMs": 0.0,
            "ttfbMs": 0.01,
            "transferMs": 0.01,
            "sizeBytes": 0.0
          }
        }
      },
      "calls": "IGNORED",
      "actions": {
        "notifications": "NON_NULL"
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls"
    ]
  }
}
