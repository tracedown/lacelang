{
  "id": "null_prev_runvars_treated_as_first_run",
  "description": "When prev exists but prev.runVars does not contain laceBaseline.stats, the extension behaves like a first run: no spike detection, stats initialized from scratch.",
  "spec_refs": ["lace-extensions.md §13"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceBaseline"],
    "prev_results": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [],
      "actions": {}
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "laceBaseline.stats": {
          "count": 1,
          "sums": "IGNORED"
        }
      },
      "calls": "IGNORED",
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls",
      "actions.notifications"
    ]
  }
}
