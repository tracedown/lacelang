{
  "id": "below_min_entries_no_detection",
  "description": "When previous stats count (3) is below min_entries (5), spike detection is inactive even if metrics would otherwise spike. Stats still accumulate.",
  "spec_refs": ["lace-extensions.md §13"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["laceNotifications", "laceBaseline"],
    "prev_results": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "laceBaseline.stats": {
          "count": 3,
          "sums": {
            "responseTimeMs": 0.003,
            "dnsMs": 0.003,
            "connectMs": 0.003,
            "tlsMs": 0.0,
            "ttfbMs": 0.003,
            "transferMs": 0.003,
            "sizeBytes": 0.003
          }
        }
      },
      "calls": [],
      "actions": {}
    },
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {
        "laceBaseline.stats": {
          "count": 4,
          "sums": "IGNORED"
        }
      },
      "calls": "IGNORED",
      "actions": {}
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls",
      "actions.notifications"
    ]
  }
}
