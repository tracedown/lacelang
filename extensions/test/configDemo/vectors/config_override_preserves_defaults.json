{
  "id": "config_override_preserves_defaults",
  "description": "lace.config overrides win for keys present in both; keys absent from lace.config retain their .config defaults. Override greeting=world, threshold retains default 5.",
  "spec_refs": ["lace-extensions.md §2.3", "lace-extensions.md §11.1"],
  "type": "extension",
  "requires": ["extensions", "actions"],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/ok\").expect(status: 200)\n",
    "variables": {},
    "extensions": ["configDemo"],
    "lace_config": "[extensions.configDemo]\ngreeting = \"world\"\n",
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": "IGNORED",
      "actions": {
        "config_echo": [
          {"key": "greeting", "value": "world"},
          {"key": "threshold", "value": 5}
        ]
      }
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls"
    ]
  }
}
