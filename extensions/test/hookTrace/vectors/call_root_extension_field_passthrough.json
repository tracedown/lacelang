{
  "id": "call_root_extension_field_passthrough",
  "description": "An extension (hookTrace) registers a call-root field `traceTag`. With the extension active, the executor passes the field through to `calls[0].config` without interpretation (spec \u00a715.14, lace-extensions.md \u00a73.1). The parser stores unknown call-config identifiers under `config.extensions`, so the emitted shape is `calls[0].config.extensions.traceTag == \"bar\"`.",
  "spec_refs": [
    "lace-spec.md \u00a710",
    "lace-spec.md \u00a715.14",
    "lace-extensions.md \u00a73.1"
  ],
  "type": "extension",
  "requires": [
    "extensions",
    "actions"
  ],
  "input": {
    "source": "get(\"http://127.0.0.1:{port}/x\", { traceTag: \"bar\" }).expect(status: 200)\n",
    "variables": {},
    "extensions": [
      "hookTrace"
    ],
    "http_mock": [
      {
        "callIndex": 0,
        "outcome": "response",
        "status": 200,
        "headers": {},
        "body": ""
      }
    ]
  },
  "expected": {
    "result": {
      "outcome": "success",
      "startedAt": "1970-01-01T00:00:00Z",
      "endedAt": "1970-01-01T00:00:00Z",
      "runVars": {},
      "calls": [
        {
          "index": 0,
          "outcome": "success",
          "startedAt": "1970-01-01T00:00:00Z",
          "endedAt": "1970-01-01T00:00:00Z",
          "request": "IGNORED",
          "response": "IGNORED",
          "redirects": [],
          "assertions": "IGNORED",
          "config": {
            "timeout": {"ms": 30000, "action": "fail", "retries": 0},
            "redirects": {"follow": true, "max": 10},
            "security": {"rejectInvalidCerts": true},
            "extensions": {
              "traceTag": "bar"
            }
          },
          "warnings": [],
          "error": null
        }
      ],
      "actions": "IGNORED"
    },
    "ignore": [
      "startedAt",
      "endedAt",
      "calls[*].startedAt",
      "calls[*].endedAt",
      "calls[*].request",
      "calls[*].response",
      "calls[*].assertions",
      "actions"
    ]
  }
}
